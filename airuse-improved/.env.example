# ── Groq API Keys ─────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
# Add _2, _3, _4 variants to enable key rotation and avoid rate limits
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=optional_second_key
GROQ_API_KEY_3=optional_third_key
GROQ_API_KEY_4=optional_fourth_key

# ── Model (optional — defaults to llama-3.3-70b-versatile) ───────────────────
# Options: llama-3.3-70b-versatile | llama-3.1-70b-versatile | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ── Port (optional — defaults to 3001) ────────────────────────────────────────
PORT=3001

# ── Supabase (Auth + Resume Storage) ──────────────────────────────────────────
# Create a free project at: https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
