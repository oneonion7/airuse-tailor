{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js",
      "headers": { "x-matched-path": "/api/$1" }
    },
    {
      "src": "/(.*)",
      "dest": "backend/server.js"
    }
  ]
}
